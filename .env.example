# ============================================================
#  IAMOneStop — Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env — it is listed in .gitignore.
# ============================================================

# ─── Core NextAuth ───────────────────────────────────────────
# Full public URL of this app (no trailing slash)
#   Dev:  http://localhost:3000
#   Prod: https://iamone-prod.azurewebsites.net
NEXTAUTH_URL=http://localhost:3000

# Random secret — must be at least 32 characters.
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-change-in-production-min-32-chars

# ─── Database ────────────────────────────────────────────────
#   Local dev:     file:./prisma/dev.db
#   Azure App Svc: file:/home/data/app.db   (persistent /home mount)
DATABASE_URL="file:./prisma/dev.db"

# ─── Microsoft Entra ID (Azure AD) SSO ───────────────────────
# Required for Azure AD login. Obtain from your App Registration.
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Redirect URI registered in the Entra App Registration:
#   Dev:  http://localhost:3000/api/auth/callback/azure-ad
#   Prod: https://iamone-prod.azurewebsites.net/api/auth/callback/azure-ad
AZURE_AD_REDIRECT_URI=http://localhost:3000/api/auth/callback/azure-ad

# ─── Entra RBAC Group Object IDs ─────────────────────────────
# These group IDs determine which role users receive on sign-in.
# IAMOneStop_Admin     → full access (including Settings)
# IAMOneStop_Operators → task + audit access only
# Values are set in code (src/lib/auth.ts) — listed here for reference.
# ENTRA_GROUP_ADMIN    = 440465df-d398-4db8-866b-27644049c700
# ENTRA_GROUP_OPERATOR = 557247c7-111b-4971-b380-cd0f21b731e3

# ─── Active Directory / LDAP ─────────────────────────────────
AD_DOMAIN=company.com
AD_DC_SERVER=dc01.company.com
AD_BASE_OU=DC=company,DC=com

# Default OUs for different account types
AD_OU_USERS=OU=Users,DC=company,DC=com
AD_OU_SERVICE=OU=ServiceAccounts,DC=company,DC=com
AD_OU_RPA=OU=RPA,DC=company,DC=com
AD_OU_SHARED=OU=SharedAccounts,DC=company,DC=com

# ─── PowerShell ──────────────────────────────────────────────
# Absolute path to the directory containing the IAM PowerShell scripts
#   Windows: C:\Scripts\IAM
#   App Svc: /home/site/wwwroot/powershell-scripts
PS_SCRIPTS_PATH=C:\\Scripts\\IAM

# Execution timeout in milliseconds (default 5 minutes)
PS_TIMEOUT_MS=300000

# Execution policy: Bypass | RemoteSigned | Unrestricted
PS_EXECUTION_POLICY=RemoteSigned

# Verbose PS logging (true = log full output to console)
PS_VERBOSE_LOGGING=true

# Set to "true" on dev machines that have real AD/PowerShell available.
# When false (default) a safe mock is returned instead of running scripts.
# In production (NODE_ENV=production) real PowerShell is ALWAYS used.
PS_USE_REAL=false

# ─── Resend Email Notifications (used by student registration) ──
# Generate an API key in https://resend.com and verify your sender domain/email
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@company.com

# ─── SMTP / Email Notifications (optional/legacy) ──────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=iam-portal@company.com

# ─── Misc ────────────────────────────────────────────────────
NODE_ENV=development
